<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.salary.mapper.PerformanceMapper">

    <!-- 根据员工ID和年月查询绩效记录（薪资计算时调用） -->
    <select id="selectByEmpAndMonth" resultType="com.salary.entity.Performance">
        SELECT * FROM t_performance
        WHERE emp_id    = #{empId}
          AND `year_month` = #{yearMonth}
        LIMIT 1
    </select>

</mapper>
