<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.salary.mapper.UserMapper">

    <!--
        根据用户名查询用户（含密码字段）
        注意：t_user 实体的 password 字段标注了 @TableField(select = false)
        所以 selectById 等 MP 方法不会返回密码，登录验证必须走这里
    -->
    <select id="selectByUsernameWithPassword" resultType="com.salary.entity.User">
        SELECT id, username, password, role, real_name, avatar, email,
               status, last_login_time, last_login_ip, create_time, update_time
        FROM t_user
        WHERE username = #{username}
          AND status = 1
        LIMIT 1
    </select>

</mapper>
